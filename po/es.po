#: src/application.rs data/io.github.juancarlosbernal.FolderPlay.metainfo.xml.in
msgid "Designed with a strong focus on Lossless Hi-Res audio playback."
msgstr "Diseñado con un fuerte enfoque en la reproducción de audio Lossless Hi-Res."

#: src/preferences.rs
msgid "Audio Output"
msgstr "Salida de audio"

#: src/preferences.rs
msgid ""
"HiFi sends audio directly to your DAC without resampling. Standard uses "
"PulseAudio for maximum compatibility."
msgstr ""
"HiFi envía el audio directamente a tu DAC sin remuestreo. Estándar usa "
"PulseAudio para máxima compatibilidad."

#: src/preferences.rs
msgid "Output"
msgstr "Salida"

#: src/preferences.rs
msgid "Automatic"
msgstr "Automático"

#: src/preferences.rs
msgid "HiFi (Bit-perfect)"
msgstr "HiFi (Bit-perfect)"

#: src/preferences.rs
msgid "Standard (PulseAudio)"
msgstr "Estándar (PulseAudio)"

#: src/preferences.rs
msgid ""
"Selects the best available output. Prefers HiFi when PipeWire is present, "
"otherwise falls back to Standard."
msgstr ""
"Selecciona la mejor salida disponible. Prefiere HiFi cuando PipeWire está "
"presente, de lo contrario usa Estándar."

#: src/preferences.rs
msgid ""
"Passthrough output for bit-perfect playback via PipeWire or ALSA. Ideal for "
"Hi-Res lossless audio (96 – 192 kHz)."
msgstr ""
"Salida directa para reproducción bit-perfect vía PipeWire o ALSA. Ideal "
"para audio Hi-Res sin pérdida (96 – 192 kHz)."

#: src/preferences.rs
msgid ""
"Legacy output via PulseAudio. Audio is resampled to a common rate (44.1 – "
"48 kHz). Compatible with all systems."
msgstr ""
"Salida tradicional vía PulseAudio. El audio se remuestrea a una tasa común "
"(44.1 – 48 kHz). Compatible con todos los sistemas."

