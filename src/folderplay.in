import os
import sys
import signal
import locale
import gettext

VERSION = '@VERSION@'
pkgdatadir = '@pkgdatadir@'
localedir = '@localedir@'

sys.path.insert(1, pkgdatadir)
signal.signal(signal.SIGINT, signal.SIG_DFL)
locale.setlocale(locale.LC_ALL, '')
locale.bindtextdomain('folderplay', localedir)
locale.textdomain('folderplay')
gettext.bindtextdomain('folderplay', localedir)
gettext.textdomain('folderplay')

if __name__ == '__main__':
    import gi

    from gi.repository import Gio
    resource = Gio.Resource.load(os.path.join(pkgdatadir, 'folderplay.gresource'))
    resource._register()

    from folderplay import main
    sys.exit(main.main(VERSION))
